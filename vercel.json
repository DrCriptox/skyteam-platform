{
  "functions": {
    "api/landing-page.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/landing.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/event-pages.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/event-landing.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/upload-event.js": {
      "memory": 128,
      "maxDuration": 15
    },
    "api/whatsapp-admin.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
    }
  ],
  "redirects": [
    {
      "source": "/agenda/:user",
      "destination": "/?agenda=:user",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/registro",
      "destination": "/index.html"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/landing",
      "destination": "/api/landing-page"
    },
    {
      "source": "/landing/:ref",
      "destination": "/api/landing-page?ref=:ref"
    },
    {
      "source": "/evento/:path*",
      "destination": "/api/event-landing?slug=:path*"
    },
    {
      "source": "/api/push",
      "destination": "/api/send-email"
    },
    {
      "source": "/api/photo",
      "destination": "/api/onboarding"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/send-email",
            "schedule": "*/15 * * * *"
    }
  ]
}
